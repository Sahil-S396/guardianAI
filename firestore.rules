rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: is user authenticated?
    function isAuthed() {
      return request.auth != null;
    }

    // Hospital data — authenticated users can read and write
    match /hospitals/{hospitalId}/{collection}/{docId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed() && request.auth.token.admin == true;
    }
  }
}
